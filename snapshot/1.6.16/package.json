{
  "name": "markdown-navigator",
  "displayName": "Markdown Navigator",
  "description": "Navigate and preview all Markdown files in your workspace",
  "version": "1.6.16",
  "publisher": "Websolete",
  "author": {
    "name": "Kevin J. Miller",
    "email": "websolete@gmail.com"
  },
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/websolete/markdown-navigator.git"
  },
  "bugs": {
    "url": "https://github.com/websolete/markdown-navigator/issues"
  },
  "homepage": "https://github.com/websolete/markdown-navigator#readme",
  "keywords": [
    "markdown",
    "navigation",
    "document",
    "outline",
    "preview",
    "tree view",
    "headers"
  ],
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "license": "MIT",
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "markdown-navigator",
          "title": "Markdown Navigator",
          "icon": "./icons/m-compass-clean.svg"
        }
      ]
    },
    "views": {
      "markdown-navigator": [
        {
          "id": "markdownFavorites",
          "name": "Favorites",
          "icon": "./icons/bullets/search-highlight.svg"
        },
        {
          "id": "markdownNavigator",
          "name": "Documentation Files",
          "icon": "./icons/markdown.svg"
        },
        {
          "id": "markdownHeaders",
          "name": "Current Document",
          "icon": "./icons/header-list.svg"
        }
      ]
    },
    "menus": {
      "view/item/context": [
        {
          "command": "markdown-navigator.previewMarkdownFile",
          "when": "view == markdownNavigator && viewItem == markdownFile",
          "group": "navigation"
        },
        {
          "command": "markdown-navigator.copyHeaderLink",
          "when": "view == markdownHeaders && viewItem == markdownHeader",
          "group": "navigation"
        },
        {
          "command": "markdown-navigator.markAsRead",
          "when": "view == markdownNavigator && viewItem == markdownFile",
          "group": "status"
        },
        {
          "command": "markdown-navigator.markAsUnread",
          "when": "view == markdownNavigator && viewItem == markdownFile",
          "group": "status"
        },
        {
          "command": "markdown-navigator.markAsPartial",
          "when": "view == markdownNavigator && viewItem == markdownFile",
          "group": "status"
        },
        {
          "command": "markdown-navigator.addToFavorites",
          "when": "view == markdownNavigator && viewItem == markdownFile",
          "group": "favorites"
        },
        {
          "command": "markdown-navigator.removeFromFavorites",
          "when": "view == markdownFavorites && viewItem == markdownFile",
          "group": "favorites"
        }
      ],
      "view/title": [
        {
          "command": "markdown-navigator.refresh",
          "when": "view == markdownNavigator",
          "group": "navigation"
        },
        {
          "command": "markdownNavigator.toggleGitIgnore",
          "when": "view == markdownNavigator",
          "group": "navigation"
        },
        {
          "command": "markdown-navigator.searchInSidebar",
          "when": "view == markdownNavigator",
          "group": "navigation@1"
        },
        {
          "command": "markdown-navigator.clearSearch",
          "when": "view == markdownNavigator && markdown-navigator:isSearchActive",
          "group": "navigation@2"
        },
        {
          "command": "markdown-navigator.searchMarkdownFiles",
          "when": "view == markdownNavigator",
          "group": "navigation@3"
        },
        {
          "command": "markdown-navigator.refreshHeaders",
          "when": "view == markdownHeaders",
          "group": "navigation"
        },
        {
          "command": "markdown-navigator.showWorkspaceStats",
          "when": "view == markdownNavigator",
          "group": "navigation@4"
        },
        {
          "command": "markdown-navigator.selectPreviewTheme",
          "when": "view == markdownNavigator",
          "group": "navigation@5"
        }
      ]
    },
    "commands": [
      {
        "command": "markdown-navigator.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "markdownNavigator.toggleGitIgnore",
        "title": "Toggle .gitignore Filtering",
        "icon": "$(source-control)"
      },
      {
        "command": "markdown-navigator.previewMarkdownFile",
        "title": "Preview Markdown File"
      },
      {
        "command": "markdown-navigator.refreshHeaders",
        "title": "Refresh Headers",
        "icon": "$(refresh)"
      },
      {
        "command": "markdown-navigator.copyHeaderLink",
        "title": "Copy Header Link"
      },
      {
        "command": "markdown-navigator.goToHeader",
        "title": "Go to Header in Preview"
      },
      {
        "command": "markdown-navigator.searchMarkdownFiles",
        "title": "Search Markdown Files",
        "icon": "$(search)"
      },
      {
        "command": "markdown-navigator.searchInSidebar",
        "title": "Filter in Sidebar",
        "icon": "$(filter)"
      },
      {
        "command": "markdown-navigator.clearSearch",
        "title": "Clear Search Filter",
        "icon": "$(clear-all)"
      },
      {
        "command": "markdown-navigator.markAsRead",
        "title": "Mark as Read",
        "icon": "$(check)"
      },
      {
        "command": "markdown-navigator.markAsUnread",
        "title": "Mark as Unread",
        "icon": "$(circle-large-outline)"
      },
      {
        "command": "markdown-navigator.markAsPartial",
        "title": "Mark as 50% Read",
        "icon": "$(clock)"
      },
      {
        "command": "markdown-navigator.showWorkspaceStats",
        "title": "Show Workspace Statistics",
        "icon": "$(graph)"
      },
      {
        "command": "markdown-navigator.openFile",
        "title": "Open Markdown File"
      },
      {
        "command": "markdown-navigator.openInEditor",
        "title": "Open in Editor"
      },
      {
        "command": "markdown-navigator.copyPath",
        "title": "Copy Path"
      },
      {
        "command": "markdown-navigator.addToFavorites",
        "title": "Add to Favorites",
        "icon": "$(bookmark)"
      },
      {
        "command": "markdown-navigator.removeFromFavorites",
        "title": "Remove from Favorites",
        "icon": "$(bookmark-remove)"
      },
      {
        "command": "markdown-navigator.selectPreviewTheme",
        "title": "Select Preview Theme",
        "icon": "$(symbol-color)"
      },
      {
        "command": "markdown-navigator.resetStyles",
        "title": "Reset Markdown Styles",
        "icon": "$(trash)"
      }
    ],
    "configuration": {
      "title": "Markdown Navigator",
      "properties": {
        "markdownNavigator.previewTheme": {
          "type": "string",
          "enum": [
            "academic",
            "dark-elegant",
            "dark-enhanced",
            "dark-technical",
            "dark-vibrant",
            "default",
            "github",
            "light-modern",
            "light-sepia",
            "light-technical",
            "minimal"
          ],
          "enumDescriptions": [
            "Academic paper style with serif fonts and proper spacing",
            "Elegant dark theme with muted colors and refined typography",
            "Enhanced dark mode with better contrast and readability",
            "Technical documentation dark theme optimized for code blocks",
            "Vibrant dark theme with colorful accents",
            "VS Code default markdown preview styling",
            "GitHub-style markdown with clean typography",
            "Modern light theme with clean layout and subtle accents",
            "Light sepia-toned theme for comfortable reading",
            "Technical documentation light theme with code-friendly styling",
            "Minimal style with focus on content"
          ],
          "default": "default",
          "description": "Choose the visual theme for markdown previews"
        },
        "markdownNavigator.customCssPath": {
          "type": "string",
          "default": "",
          "description": "Path to custom CSS file for markdown preview (optional, overrides theme selection)"
        },
        "markdownNavigator.useRelativePaths": {
          "type": "boolean",
          "default": true,
          "description": "Use file URIs instead of absolute paths for theme CSS files (recommended for better compatibility)"
        },
        "markdownNavigator.enableCfmlHighlighting": {
          "type": "boolean",
          "default": true,
          "description": "Enable syntax highlighting for CFML code blocks in markdown previews"
        }
      }
    }
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "dependencies": {
    "ignore": "^5.3.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.100.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "eslint": "^9.25.1",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.5.2"
  }
}
