{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "npm",
			"script": "compile",
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"presentation": {
				"reveal": "silent"
			},
			"problemMatcher": ["$tsc"]
		},
		{
			"label": "Run Extension",
			"type": "shell",
			"command": "code",
			"args": [
				"--extensionDevelopmentPath=${workspaceFolder}",
				"${workspaceFolder}"
			],
			"group": "test",
			"isBackground": true,
			"problemMatcher": []
		}
	]
}