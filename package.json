{
    "name": "markdown-navigator",
    "displayName": "Markdown Navigator",
    "description": "Navigate and preview all Markdown files in your workspace",
    "version": "1.6.31",
    "publisher": "Websolete",
    "author": {
        "name": "Kevin J. Miller",
        "email": "websolete@gmail.com"
    },
    "icon": "icon.png",
    "repository": {
        "type": "git",
        "url": "https://github.com/websolete/markdown-navigator.git"
    },
    "bugs": {
        "url": "https://github.com/websolete/markdown-navigator/issues"
    },
    "homepage": "https://github.com/websolete/markdown-navigator#readme",
    "keywords": [
        "markdown",
        "navigation",
        "document",
        "outline",
        "preview",
        "tree view",
        "headers"
    ],
    "engines": {
        "vscode": "^1.100.0"
    },
    "categories": [
        "Other"
    ],
    "license": "MIT",
    "activationEvents": [],
    "main": "./dist/extension.js",
    "contributes": {
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "markdown-navigator",
                    "title": "Markdown Navigator",
                    "icon": "./icons/m-compass-clean.svg"
                }
            ]
        },
        "views": {
            "markdown-navigator": [
                {
                    "id": "markdownFavorites",
                    "name": "Favorites",
                    "icon": "./icons/bullets/search-highlight.svg"
                },
                {
                    "id": "markdownNavigator",
                    "name": "Documentation Files",
                    "icon": "./icons/markdown.svg"
                },
                {
                    "id": "markdownHeaders",
                    "name": "Current Document",
                    "icon": "./icons/header-list.svg"
                }
            ]
        },
        "menus": {
            "view/item/context": [
                {
                    "command": "markdown-navigator.previewMarkdownFile",
                    "when": "view == markdownNavigator && viewItem == markdownFile",
                    "group": "navigation"
                },
                {
                    "command": "markdown-navigator.openEnhancedPreview",
                    "when": "view == markdownNavigator && viewItem == markdownFile",
                    "group": "navigation"
                },
                {
                    "command": "markdown-navigator.copyHeaderLink",
                    "when": "view == markdownHeaders && viewItem == markdownHeader",
                    "group": "navigation"
                },
                {
                    "command": "markdown-navigator.markAsRead",
                    "when": "view == markdownNavigator && viewItem == markdownFile",
                    "group": "status"
                },
                {
                    "command": "markdown-navigator.markAsUnread",
                    "when": "view == markdownNavigator && viewItem == markdownFile",
                    "group": "status"
                },
                {
                    "command": "markdown-navigator.markAsPartial",
                    "when": "view == markdownNavigator && viewItem == markdownFile",
                    "group": "status"
                },
                {
                    "command": "markdown-navigator.addToFavorites",
                    "when": "view == markdownNavigator && viewItem == markdownFile",
                    "group": "favorites"
                },
                {
                    "command": "markdown-navigator.removeFromFavorites",
                    "when": "view == markdownFavorites && viewItem == markdownFile",
                    "group": "favorites"
                }
            ],
            "view/title": [
                {
                    "command": "markdown-navigator.refresh",
                    "when": "view == markdownNavigator",
                    "group": "navigation"
                },
                {
                    "command": "markdownNavigator.toggleGitIgnore",
                    "when": "view == markdownNavigator",
                    "group": "navigation"
                },
                {
                    "command": "markdown-navigator.searchInSidebar",
                    "when": "view == markdownNavigator",
                    "group": "navigation@1"
                },
                {
                    "command": "markdown-navigator.clearSearch",
                    "when": "view == markdownNavigator && markdown-navigator:isSearchActive",
                    "group": "navigation@2"
                },
                {
                    "command": "markdown-navigator.searchMarkdownFiles",
                    "when": "view == markdownNavigator",
                    "group": "navigation@3"
                },
                {
                    "command": "markdown-navigator.refreshHeaders",
                    "when": "view == markdownHeaders",
                    "group": "navigation"
                },
                {
                    "command": "markdown-navigator.showWorkspaceStats",
                    "when": "view == markdownNavigator",
                    "group": "navigation@4"
                }
            ]
        },
        "commands": [
            {
                "command": "markdown-navigator.refresh",
                "title": "Refresh",
                "icon": "$(refresh)"
            },
            {
                "command": "markdownNavigator.toggleGitIgnore",
                "title": "Toggle .gitignore Filtering",
                "icon": "$(source-control)"
            },
            {
                "command": "markdown-navigator.previewMarkdownFile",
                "title": "Preview Markdown File"
            },
            {
                "command": "markdown-navigator.refreshHeaders",
                "title": "Refresh Headers",
                "icon": "$(refresh)"
            },
            {
                "command": "markdown-navigator.copyHeaderLink",
                "title": "Copy Header Link"
            },
            {
                "command": "markdown-navigator.goToHeader",
                "title": "Go to Header in Preview"
            },
            {
                "command": "markdown-navigator.searchMarkdownFiles",
                "title": "Search Markdown Files",
                "icon": "$(search)"
            },
            {
                "command": "markdown-navigator.searchInSidebar",
                "title": "Filter in Sidebar",
                "icon": "$(filter)"
            },
            {
                "command": "markdown-navigator.clearSearch",
                "title": "Clear Search Filter",
                "icon": "$(clear-all)"
            },
            {
                "command": "markdown-navigator.markAsRead",
                "title": "Mark as Read",
                "icon": "$(check)"
            },
            {
                "command": "markdown-navigator.markAsUnread",
                "title": "Mark as Unread",
                "icon": "$(circle-large-outline)"
            },
            {
                "command": "markdown-navigator.markAsPartial",
                "title": "Mark as 50% Read",
                "icon": "$(clock)"
            },
            {
                "command": "markdown-navigator.showWorkspaceStats",
                "title": "Show Workspace Statistics",
                "icon": "$(graph)"
            },
            {
                "command": "markdown-navigator.openFile",
                "title": "Open Markdown File"
            },
            {
                "command": "markdown-navigator.openInEditor",
                "title": "Open in Editor"
            },
            {
                "command": "markdown-navigator.copyPath",
                "title": "Copy Path"
            },
            {
                "command": "markdown-navigator.addToFavorites",
                "title": "Add to Favorites",
                "icon": "$(bookmark)"
            },
            {
                "command": "markdown-navigator.removeFromFavorites",
                "title": "Remove from Favorites",
                "icon": "$(bookmark-remove)"
            },
            {
                "command": "markdown-navigator.openEnhancedPreview",
                "title": "Open Enhanced Preview",
                "icon": "$(preview)"
            },
            {
                "command": "markdown-navigator.toggleEnhancedPreviewDebug",
                "title": "Toggle Enhanced Preview Debug Mode",
                "icon": "$(debug)"
            }
        ],
        "configuration": {
            "title": "Markdown Navigator",
            "properties": {
                "markdownNavigator.previewMode": {
                    "type": "string",
                    "enum": [
                        "enhanced",
                        "native"
                    ],
                    "default": "enhanced",
                    "markdownDescription": "Choose which preview implementation the shared preview-opening path uses. `enhanced` keeps the current webview fallback, while `native` routes through VS Code's built-in markdown preview commands."
                },
                "markdownNavigator.enhancedPreview.debugMode": {
                    "type": "boolean",
                    "default": false,
                    "description": "Enable debug mode for enhanced preview to display diagnostic information"
                }
            }
        }
    },
    "scripts": {
        "check-types": "tsc --noEmit",
        "compile": "npm run check-types && npm run build:dev",
        "build:dev": "node esbuild.js",
        "watch": "node esbuild.js --watch",
        "build:prod": "node esbuild.js --production",
        "package": "npm run check-types && npm run lint && npm run build:prod",
        "vscode:prepublish": "npm run package",
        "pack": "npx @vscode/vsce package",
        "package:vsix": "npm run pack",
        "build:pack": "npm run package && npm run pack",
        "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
        "lint": "eslint .",
        "pretest": "npm run lint",
        "test": "vscode-test"
    },
    "dependencies": {
        "ignore": "^5.3.0",
        "marked": "^15.0.12",
        "sanitize-html": "^2.17.4"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.10",
        "@types/node": "20.x",
        "@types/vscode": "^1.100.0",
        "@vscode/test-cli": "^0.0.10",
        "@vscode/test-electron": "^2.5.2",
        "@vscode/vsce": "^3.6.0",
        "esbuild": "^0.25.8",
        "eslint": "^9.25.1",
        "typescript": "^5.9.2"
    }
}
