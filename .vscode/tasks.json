{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "npm",
			"script": "compile",
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"presentation": {
				"reveal": "silent"
			},
			"problemMatcher": ["$tsc"]
		},
		{
			"type": "npm",
			"script": "watch",
			"isBackground": true,
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			},
			"problemMatcher": []
		},
		{
			"type": "npm",
			"script": "package",
			"group": "build",
			"presentation": {
				"reveal": "silent"
			},
			"problemMatcher": []
		},
		{
			"type": "npm",
			"script": "build:pack",
			"group": "build",
			"presentation": {
				"reveal": "always"
			},
			"problemMatcher": []
		},
		{
			"type": "npm",
			"script": "clean",
			"presentation": {
				"reveal": "silent"
			},
			"problemMatcher": []
		},
		{
			"label": "Run Extension",
			"type": "shell",
			"command": "code",
			"args": [
				"--extensionDevelopmentPath=${workspaceFolder}",
				"${workspaceFolder}"
			],
			"group": "test",
			"isBackground": true,
			"problemMatcher": []
		}
	]
}